# =============================================================
# SAIGON LOGISTICS — biến môi trường
# Copy file này thành `.env.local` rồi điền giá trị thật.
# Các biến NEXT_PUBLIC_* được nhúng vào client (analytics).
# =============================================================

# --- Analytics & tracking (tuỳ chọn) ---
# GA4 Measurement ID, ví dụ G-XXXXXXXXXX
NEXT_PUBLIC_GA4_ID=
# Meta (Facebook) Pixel ID
NEXT_PUBLIC_META_PIXEL_ID=

# --- Thông tin liên hệ hiển thị (tuỳ chọn, có default trong lib/site.ts) ---
NEXT_PUBLIC_HOTLINE=1900 6886
NEXT_PUBLIC_ZALO_PHONE=0901234567
NEXT_PUBLIC_SITE_URL=https://saigon-logistics.vercel.app

# --- Nhận lead: chọn MỘT trong các kênh dưới đây ---
# (Route handler /api/lead sẽ tự ưu tiên theo thứ tự: Webhook -> Resend -> Telegram -> log)

# 1) Google Sheet qua Apps Script Web App, hoặc bất kỳ webhook nhận JSON nào
LEAD_WEBHOOK_URL=

# 2) Gửi email qua Resend (https://resend.com)
RESEND_API_KEY=
LEAD_EMAIL_TO=sale@saigon-logistics.vn
LEAD_EMAIL_FROM=lead@saigon-logistics.vn

# 3) Bắn thông báo vào Telegram bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
