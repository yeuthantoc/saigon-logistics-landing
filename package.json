  },
  "devDependencies": {
    "@types/node": "20.14.10",
    "@types/react": "19.0.1",
    "@types/react-dom": "19.0.1",
    "autoprefixer": "10.4.20",
    "postcss": "8.4.49",
    "tailwindcss": "3.4.16",
    "typescript": "5.6.3",
    "wrangler": "^4.106.0"
  }
}
